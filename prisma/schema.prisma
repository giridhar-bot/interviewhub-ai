model Subscription {
  id       String           @id @default(uuid())
  userId   String
  plan     SubscriptionPlan
  startsAt DateTime
  expiresAt DateTime
  active   Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  amount        Float
  currency      String        @default("INR")
  status        PaymentStatus
  provider      String
  transactionId String        @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("payments")
}

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  discountPct Float
  expiresAt   DateTime?
  active      Boolean   @default(true)

  @@map("coupons")
}

model NotificationTemplate {
  id      String @id @default(uuid())
  name    String @unique
  subject String
  body    String @db.Text
  channel String

  createdAt DateTime @default(now())

  @@map("notification_templates")
}

model AdminSetting {
  id       String @id @default(uuid())
  category String
  key      String
  value    Json

  @@unique([category, key])
  @@map("admin_settings")
}

model PlatformAnalytics {
  id          String   @id @default(uuid())
  metric      String
  metricValue Float
  recordedAt  DateTime @default(now())

  @@index([metric])
  @@map("platform_analytics")
}

model AuditEvent {
  id       String  @id @default(uuid())
  actorId  String?
  action   String
  entity   String
  entityId String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("audit_events")
}
