// 10. SEO DOMAIN
// ═══════════════════════════════════════════════

model SlugHistory {
  id         String   @id @default(uuid())
  oldSlug    String
  newSlug    String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@index([oldSlug])
  @@map("slug_history")
}

model MetaData {
  id          String  @id @default(uuid())
  entityType  String
  entityId    String
  title       String?
  description String? @db.Text
  keywords    String[]
  ogImage     String?
  canonical   String?
  noIndex     Boolean @default(false)

  @@unique([entityType, entityId])
  @@map("meta_data")
}

model Redirect {
  id        String   @id @default(uuid())
  fromPath  String   @unique
  toPath    String
  statusCode Int     @default(301)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("redirects")
}

model FAQ {
  id         String   @id @default(uuid())
  question   String
  answer     String   @db.Text
  entityType String?
  entityId   String?
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

model SchemaMarkup {
  id         String @id @default(uuid())
  entityType String
  entityId   String
  type       String // Article, FAQPage, Course, Organization
  data       Json

  @@unique([entityType, entityId])
  @@map("schema_markups")
}

// ═══════════════════════════════════════════════
// 11. ADMIN DOMAIN
// ═══════════════════════════════════════════════

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  category  String?
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  enabled     Boolean  @default(false)
  rules       Json?    // { roles: ["ADMIN"], plans: ["PRO"] }
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model Announcement {
  id        String        @id @default(uuid())
  title     String
  content   String        @db.Text
  type      String        @default("info") // info, warning, success, error
  status    ContentStatus @default(DRAFT)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("announcements")
}

model Report {
  id          String       @id @default(uuid())
  reporterId  String
  targetId    String?
  entityType  String
  entityId    String
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())

  reporter User  @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User? @relation("ReportTarget", fields: [targetId], references: [id])

  @@index([status])
  @@index([entityType, entityId])
  @@map("reports")
}

model ModerationQueue {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  reason     String
  priority   Int      @default(0) // higher = more urgent
  assignedTo String?
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([resolvedAt])
  @@index([priority])
  @@map("moderation_queue")
}

// ═══════════════════════════════════════════════
// 12. ANALYTICS DOMAIN
// ═══════════════════════════════════════════════

model PageView {
  id         String   @id @default(uuid())
  path       String
  userId     String?
  sessionId  String?
  referrer   String?
  userAgent  String?
  country    String?
  device     String?
  duration   Int?     // seconds
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([path])
  @@index([userId])
  @@index([createdAt])
  @@map("page_views")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  name      String
  userId    String?
  sessionId String?
  properties Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([name])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

model SessionAnalytics {
  id         String   @id @default(uuid())
  sessionId  String   @unique
  userId     String?
  startedAt  DateTime
  endedAt    DateTime?
  pageCount  Int      @default(0)
  duration   Int?     // seconds
  device     String?
  browser    String?
  os         String?
  country    String?

  @@index([userId])
  @@index([startedAt])
  @@map("session_analytics")
}

model ContentAnalytics {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  date       DateTime @db.Date
  views      Int      @default(0)
  uniqueViews Int     @default(0)
  avgDuration Int?    // seconds
  bounceRate Float?
  shares     Int      @default(0)

  @@unique([entityType, entityId, date])
  @@index([date])
  @@map("content_analytics")
}

